{
    "csv_path": "../Data/diabetes.csv",
    "task_type": "1",
    "target_column": "Outcome",
    "execution_mode": "manual",
    "hyperparameters": {
        "decision_tree": {
            "max_depth": 6,
            "min_samples_split": 2,
            "min_samples_leaf": 1,
            "criterion": "gini"
        },
        "logistic_regression": {
            "C": 1.0,
            "penalty": "l2",
            "solver": "lbfgs"
        },
        "random_forest": {
            "n_estimators": 5,
            "max_depth": 5,
            "min_samples_split": 2,
            "min_samples_leaf": 1,
            "criterion": "gini"
        },
        "ridge_regression": {
            "alpha": 1.0,
            "solver": "auto"
        },
        "kmeans": {
            "n_clusters": 3,
            "init": "k-means++",
            "max_iter": 300
        },
        "isolation_forest": {
            "n_estimators": 5,
            "max_features": 1.0,
            "contamination": "auto"
        }
    }
}